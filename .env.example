# ─── Database / Cache ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/skypulse
REDIS_URL=redis://host:6379

# ─── HTTP transport (Context Protocol) ───────────────────────────────────────
# Port the /mcp endpoint binds to.
PORT=3000

# The public URL of this tool's /mcp endpoint. When set, createContextMiddleware
# uses it as the JWT audience for strict validation. Example once deployed:
#   TOOL_URL=https://skypulse.up.railway.app/mcp
# TOOL_URL=

# LOCAL DEV ONLY. Bypasses Context Protocol JWT verification so you can hit
# /mcp directly with curl. Hard-gated to NODE_ENV != production so accidentally
# committing this flag cannot disable auth on Railway. Leave unset in prod.
# SKIP_CTX_AUTH=true

# ─── Cron scheduler (opt-in per replica) ─────────────────────────────────────
# Set RUN_CRON=true on exactly one Railway replica. Leave unset/false elsewhere
# to avoid duplicate ingestion when scaled horizontally.
# RUN_CRON=true

# ─── T-100 data source ───────────────────────────────────────────────────────
# A stable HTTPS mirror (S3 / R2 / Railway volume / GitHub Release) of the
# latest T-100 Segment ZIP or CSV you downloaded from BTS's DL_SelectFields
# form. The weekly Sunday cron fetches this URL and re-ingests. If unset, the
# cron logs a skip message and the operator must run `npm run ingest:t100`
# manually after each BTS release.
# T100_DATA_URL=https://your-mirror.example.com/t100_segment_latest.zip

# ─── Announcements feed (optional but highly recommended) ────────────────────
# JSON feed of airline press releases. Format documented in README "Data
# Sources". Used by the daily 06:00 UTC cron.
# ANNOUNCEMENT_FEED_URL=https://example.com/announcements.json

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
